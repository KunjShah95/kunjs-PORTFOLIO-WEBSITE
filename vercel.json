{
  "rewrites": [
    {
      "source": "/.well-known/api-catalog",
      "destination": "/.well-known/api-catalog.json"
    },
    {
      "source": "/.well-known/openid-configuration",
      "destination": "/.well-known/openid-configuration.json"
    },
    {
      "source": "/.well-known/oauth-protected-resource",
      "destination": "/.well-known/oauth-protected-resource.json"
    },
    {
      "source": "/.well-known/mcp/server-card.json",
      "destination": "/.well-known/mcp/server-card.json"
    },
    {
      "source": "/.well-known/agent-skills/index.json",
      "destination": "/.well-known/agent-skills/index.json"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "Accept",
          "value": "(.*)text/markdown(.*)"
        }
      ],
      "destination": "/api/markdown"
    },
    {
      "source": "/api/llms",
      "destination": "/api/markdown"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    },
    {
      "source": "/.well-known/openid-configuration",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "source": "/.well-known/oauth-protected-resource",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "source": "/.well-known/mcp/server-card.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "source": "/.well-known/agent-skills/index.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Link",
          "value": "</.well-known/api-catalog>; rel=\"api-catalog\", </docs/api>; rel=\"service-doc\", <https://kunjshah.dev/api/llms>; rel=\"llms-full-text\", <https://kunjshah.dev/llms.txt>; rel=\"alternate\", <https://kunjshah.dev/sitemap.xml>; rel=\"sitemap\""
        }
      ]
    }
  ]
}